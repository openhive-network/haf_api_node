{
  order rate_limit before basicauth

{{ $trustedProxies := getenv "CADDY_TRUSTED_PROXIES" "private_ranges" -}}
{{ if ne $trustedProxies "" }}
  servers {
    trusted_proxies static {{ $trustedProxies }}
  }
{{ end }}

  # Import Layer4 configuration for PostgreSQL TCP proxy (if postgres-public compose yaml files are included)
  import layer4-postgres-snippets/*.snippet
}

# Simple caddy config, handles SSL and forwards everything to varnish
{$CADDY_SITES} {
{{/* TLS self-signed logic with backwards compatibility */}}
{{- $newTlsVar := getenv "CADDY_TLS_SELF_SIGNED" -}}
{{- $oldTlsVar := getenv "TLS_SELF_SIGNED_SNIPPET" -}}
{{- $useSelfSigned := true -}}
{{- if ne $newTlsVar "" -}}
  {{- $useSelfSigned = eq $newTlsVar "true" -}}
{{- else if ne $oldTlsVar "" -}}
  {{- $useSelfSigned = strings.Contains $oldTlsVar "self-signed.snippet" -}}
{{- end -}}
{{ if $useSelfSigned }}
  # Use self-signed certificate (default for development)
  tls internal
{{ end }}

  # User-provided snippets (from gitignored caddy/snippets/ directory)
  import snippets/*.snippet

  # Block known abusers
  @blacklisted_ips remote_ip 185.238.72.170 185.130.44.60 24.209.251.17
  handle @blacklisted_ips {
    respond 403
  }

{{/* Rate limiting logic */}}
{{- $rateLimitEnabled := getenv "CADDY_RATE_LIMIT_ENABLED" "true" -}}
{{ if ne $rateLimitEnabled "false" }}
  # Rate limit by client IP
  rate_limit {
    zone apilimit {
      key {client_ip}
      events {{ getenv "CADDY_RATE_LIMIT_EVENTS" "600" }}
      window {{ getenv "CADDY_RATE_LIMIT_WINDOW" "1m" }}
    }
  }
{{ end }}

  # Handle CORS pre-flight checks here, instead of passing them through
  @cors_preflight method OPTIONS
  handle @cors_preflight {
    header Access-Control-Allow-Origin "*"
    header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    header Access-Control-Allow-Headers "DNT,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Content-Range,Range"
    header Access-Control-Max-Age "3600"
    respond 204
  }

  # Serve robots.txt to block web scrapers from public sites
  handle /robots.txt {
    header Content-Type "text/plain; charset=utf-8"
    respond `User-agent: *
Disallow: /blog/
Disallow: /explorer/
Disallow: /wallet/
` 200
  }

  # reverse-proxy to the admin tools
  redir /admin /admin/

{{/* Admin local-only restriction with backwards compatibility */}}
{{- $newAdminVar := getenv "CADDY_ADMIN_LOCAL_ONLY" -}}
{{- $oldAdminVar := getenv "LOCAL_ADMIN_ONLY_SNIPPET" -}}
{{- $adminLocalOnly := true -}}
{{- if ne $newAdminVar "" -}}
  {{- $adminLocalOnly = eq $newAdminVar "true" -}}
{{- else if ne $oldAdminVar "" -}}
  {{- $adminLocalOnly = strings.Contains $oldAdminVar "local-admin-only.snippet" -}}
{{- end -}}
{{ if $adminLocalOnly }}
  # Restrict admin to localhost and Docker host (IPv4 and IPv6)
  @admin_blocked {
    path /admin /admin/*
    not {
      remote_ip 127.0.0.1 ::1 {{ getenv "DOCKER_GATEWAY_IP" }}{{ if getenv "DOCKER_GATEWAY_IP6" }} {{ getenv "DOCKER_GATEWAY_IP6" }}{{ end }}{{ if getenv "CADDY_ADMIN_ALLOWED_IPS" }} {{ getenv "CADDY_ADMIN_ALLOWED_IPS" }}{{ end }}
    }
  }
  handle @admin_blocked {
    respond "Access denied" 403
  }
{{ end }}

  # restrict the /admin endpoints to the specified protocol.  This is for the
  # usual case where you use basicauth to protect the endpoint, and want to prevent
  # it from being accessed via http.
  @admin_wrong_protocol {
    not protocol {$ADMIN_ENDPOINT_PROTOCOL}
    path /admin/*
  }
  handle @admin_wrong_protocol {
    respond "Admin endpoints are only accessible via {$ADMIN_ENDPOINT_PROTOCOL}" 403
  }

  # Route /admin/grafana to Grafana (handled separately to preserve full path)
  @admin_grafana {
    protocol {$ADMIN_ENDPOINT_PROTOCOL}
    path /admin/grafana /admin/grafana/*
  }
  handle @admin_grafana {
    import admin-snippets/*.snippet
    reverse_proxy http://grafana:3000
  }

  @admin {
    protocol {$ADMIN_ENDPOINT_PROTOCOL}
    path /admin/*
  }
  handle @admin {
    uri strip_prefix /admin
    import admin-snippets/*.snippet

    # Route /admin/pgadmin to pgAdmin
    redir /pgadmin /admin/pgadmin/
    handle_path /pgadmin/* {
      reverse_proxy http://pgadmin {
        header_up X-Script-Name "/admin/pgadmin"
      }
    }

    # Route /admin/pgadmin to pghero
    redir /pghero /admin/pghero/
    handle_path /pghero/* {
      rewrite * /admin/pghero{uri}
      reverse_proxy http://pghero:8080
    }

    # Route /admin/haproxy to haproxy's stats page
    redir /haproxy /admin/haproxy/
    handle_path /haproxy/* {
      rewrite * /admin/haproxy{uri}
      reverse_proxy http://haproxy:8000
    }

    redir /pgbadger /admin/pgbadger/
    handle_path /pgbadger/* {
      @pgbadger_report_missing not file {
        root /etc/caddy/pgbadger
        try_files index.html
      }

      redir @pgbadger_report_missing /admin/pgbadger_instructions
      root * /etc/caddy/pgbadger
      file_server
    }

    # Route /admin/dozzle to dozzle log viewer
    redir /dozzle /admin/dozzle/
    handle_path /dozzle/* {
      rewrite * /admin/dozzle{uri}
      reverse_proxy http://dozzle:8080
    }

    # Route /admin/versions to the version display app
    redir /versions /admin/versions/
    handle_path /versions/* {
      reverse_proxy http://version-display
    }

    root * /etc/caddy/admin_html
    file_server
  }

  handle /explorer {
      reverse_proxy http://block-explorer-ui
  }
  handle /explorer/* {
      reverse_proxy http://block-explorer-ui
  }

  handle /blog {
      reverse_proxy http://denser-blog
  }
  handle /blog/* {
      reverse_proxy http://denser-blog
  }

  handle /wallet {
      reverse_proxy http://denser-wallet
  }
  handle /wallet/* {
      reverse_proxy http://denser-wallet
  }

  # Route all POST calls to the root URL to jussi/drone (assume they're old-style JSON-RPC calls)
  @post_to_root {
    method POST
    path /
  }
  handle @post_to_root {
    # Add CORS headers
    header {
      Access-Control-Allow-Origin "*"
      Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
      Access-Control-Allow-Headers "DNT,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Content-Range,Range"
      Access-Control-Max-Age "3600"
    }
    reverse_proxy http://{$JSONRPC_API_SERVER_NAME}:9000 {
      # remove any CORS headers sent by jussi/drone so we don't have duplicates
      header_down -Access-Control-Allow-Origin
      header_down -Access-Control-Allow-Methods
      header_down -Access-Control-Allow-Headers
      header_down -Access-Control-Max-Age
      # we're not overriding these, they're added by drone but not necessary
      header_down -Access-Control-Allow-Credentials
      header_down -Access-Control-Expose-Headers
    }
  }

  @rest_apis {
    path /hafah-api/* /balance-api/* /reputation-api/* /hafbe-api/* /hivesense-api/* /hivemind-api/* /nft-tracker-api/* /proxy-whitelist-api/* /hived-api/* /wallet-api/* /hafsql /hafsql/* /status-api/*
  }

  handle @rest_apis {
    # Add CORS headers
    header {
      Access-Control-Allow-Origin "*"
      Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
      Access-Control-Allow-Headers "DNT,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Content-Range,Range"
      Access-Control-Max-Age "3600"
    }
    reverse_proxy http://varnish {
      # remove any CORS headers sent by the rest api servers so we don't have duplicates
      # (right now, postgrest doesn't add any of these headers, this is just defensive)
      header_down -Access-Control-Allow-Origin
      header_down -Access-Control-Allow-Methods
      header_down -Access-Control-Allow-Headers
      header_down -Access-Control-Max-Age
    }
  }

  # Route everything else (currently just swagger documentation)
  reverse_proxy http://swagger
}
